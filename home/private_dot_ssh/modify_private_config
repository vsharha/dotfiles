#!/bin/sh
set -eu

# Preserve SSH configuration owned by other tools and manage only this block.
begin_marker="# BEGIN CHEZMOI MANAGED: homelab"
end_marker="# END CHEZMOI MANAGED: homelab"
input=$(cat)

unmanaged=$(
    printf '%s\n' "$input" | awk \
        -v begin_marker="$begin_marker" \
        -v end_marker="$end_marker" '
            $0 == begin_marker { managed = 1; next }
            $0 == end_marker { managed = 0; next }
            !managed { print }
        '
)

if [ -n "$unmanaged" ]; then
    printf '%s\n\n' "$unmanaged"
fi

cat <<EOF
$begin_marker
Host homelab
    HostName debian
    User vsharha
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
$end_marker
EOF
