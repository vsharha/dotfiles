# === p10k instant prompt — keep at the VERY TOP, above everything ===
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# === per-OS locations (rendered by chezmoi) =======================
{{ if eq .chezmoi.os "darwin" -}}
_plugin_dir=/opt/homebrew/share
_p10k_theme=$_plugin_dir/powerlevel10k/powerlevel10k.zsh-theme
export PNPM_HOME="$HOME/Library/pnpm"
{{ else -}}
_plugin_dir=/usr/share/zsh/plugins
_p10k_theme=/usr/share/zsh-theme-powerlevel10k/powerlevel10k.zsh-theme
export PNPM_HOME="$HOME/.local/share/pnpm"
{{ end -}}

# === completions (must come before compinit) ===
# ~/.zfunc must precede the system dirs so its overrides (e.g. _pnpm) win.
{{ if eq .chezmoi.os "darwin" -}}
fpath=(~/.zfunc /opt/homebrew/share/zsh-completions $fpath)
{{ else -}}
fpath=(~/.zfunc $fpath)  # zsh-completions installs into site-functions, already in fpath
{{ end -}}
autoload -Uz compinit && compinit

# === powerlevel10k theme ===
source "$_p10k_theme"

# === PATH / environment ===========================================
typeset -U path
path=("$PNPM_HOME" "$HOME/go/bin" $path)
{{ if eq .chezmoi.os "darwin" -}}
path=(
  /opt/homebrew/opt/openjdk/bin
  "$HOME/.antigravity/antigravity/bin"
  "$HOME/.local/share/solana/install/active_release/bin"
  $path
  "$HOME/.lmstudio/bin"
)
{{ end -}}

# === aliases ======================================================
alias python=python3
alias pip='pip3'
alias shadcn='pnpm dlx shadcn@latest'
alias shadcn-sv='pnpm dlx shadcn-svelte@latest'
alias cc="claude --dangerously-skip-permissions"

# === fzf (fuzzy Ctrl-R history, Ctrl-T files, Alt-C cd) ===========
source <(fzf --zsh)

# === fzf-tab (replaces the completion menu with an fzf picker) =====
# Must load after compinit/fzf and BEFORE autosuggestions & syntax-highlighting.
zstyle ':completion:*' menu no                     # let fzf-tab own the menu
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':fzf-tab:*' switch-group '<' '>'           # < / > to switch groups
source "$_plugin_dir/fzf-tab/fzf-tab.zsh"

# === autosuggestions (grey history hints, → to accept) ============
# completion before history so path args (cd) are validated against the real
# cwd; raw history alone suggests stale paths that don't exist from here.
ZSH_AUTOSUGGEST_STRATEGY=(completion history)
source "$_plugin_dir/zsh-autosuggestions/zsh-autosuggestions.zsh"

# === history substring search (↑/↓ filters by substring) ==========
source "$_plugin_dir/zsh-history-substring-search/zsh-history-substring-search.zsh"
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

{{ if eq .chezmoi.os "linux" -}}
# === line navigation ==============================================
# zsh's emacs keymap doesn't bind these; both CSI variants covered.
# macOS doesn't need this — Cmd/Option arrows are handled by the terminal.
bindkey '^[[H'    beginning-of-line        # Home
bindkey '^[[1~'   beginning-of-line
bindkey '^[OH'    beginning-of-line
bindkey '^[[F'    end-of-line              # End
bindkey '^[[4~'   end-of-line
bindkey '^[OF'    end-of-line
bindkey '^[[1;5D' backward-word            # Ctrl-Left
bindkey '^[[1;5C' forward-word             # Ctrl-Right
bindkey '^[[3~'   delete-char              # Delete
bindkey '^H'      backward-kill-word       # Ctrl-Backspace
bindkey '^[[3;5~' kill-word                # Ctrl-Delete

# Shift+arrows selection, GUI-editor style (vendored plugin; not packaged
# for Arch). Shift+Home/End and Ctrl+Shift+arrows select too; typing or
# Backspace replaces/deletes the selection.
source ~/.config/zsh/zsh-shift-select.zsh

{{ end -}}

# === Tab / Shift-Tab behaviour ====================================
# zsh-autosuggestions wraps every widget to blank $POSTDISPLAY before it runs, so
# smart-tab could never see the suggestion; IGNORE_WIDGETS leaves it unwrapped.
typeset -ga ZSH_AUTOSUGGEST_IGNORE_WIDGETS
ZSH_AUTOSUGGEST_IGNORE_WIDGETS+=(smart-tab)

# Tab: accept the grey suggestion if showing, else open the fzf-tab picker.
smart-tab() {
  if [[ -n "$POSTDISPLAY" ]]; then
    zle autosuggest-accept
  else
    zle fzf-tab-complete
  fi
}
zle -N smart-tab
bindkey '^I'   smart-tab                          # Tab

# Shift-Tab: open the picker on the FIRST press. With `menu no`, fzf-tab
# inserts the longest common prefix (e.g. `drive:`) and only lists on the
# second press — it does that whenever $compstate[insert] ends in
# "unambiguous". The `menu` style is what zsh uses to set that value, so
# switching it to yes for one call makes compstate[insert]=menu and the
# picker opens at once. Public zstyle only; no fzf-tab internals.
fzf-tab-list() {
  {
    zstyle ':completion:*' menu yes
    zle fzf-tab-complete
  } always {
    zstyle ':completion:*' menu no
  }
}
zle -N fzf-tab-list
bindkey '^[[Z' fzf-tab-list                       # Shift-Tab

# === syntax highlighting (MUST be last of the plugin sources) =====
source "$_plugin_dir/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

unset _plugin_dir _p10k_theme

# === p10k prompt config — keep at the very BOTTOM =================
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
