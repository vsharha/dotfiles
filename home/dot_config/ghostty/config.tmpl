shell-integration-features = ssh-env,ssh-terminfo
{{ if eq .chezmoi.os "darwin" -}}
font-size = 18
window-height = 30
window-width = 110
theme = "Apple System Colors"
font-feature = -liga
background-opacity = 0.95
background-blur-radius = 80
# Let Shift+Home/End reach zsh for shift-select instead of adjusting the
# terminal's scrollback selection.
keybind = shift+home=unbind
keybind = shift+end=unbind
# Cmd+Shift+Left/Right: select to start/end of line. Unbound in ghostty by
# default; send the Shift+Home/End sequences (terminfo kHOM/kEND) that the
# zsh shift-select plugin already handles.
keybind = super+shift+arrow_left=text:\x1b[1;2H
keybind = super+shift+arrow_right=text:\x1b[1;2F
keybind = performable:super+c=copy_to_clipboard
# Cmd+Shift+C: forward to zsh to copy the keyboard selection.
keybind = super+shift+c=text:\x1b[99;9u
{{ else -}}
font-size = 14
window-height = 30
window-width = 110
theme = "Apple System Colors"
background-opacity = 0.98
background-blur-radius = 80
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+t=new_tab
keybind = ctrl+w=close_surface
# Let Ctrl+Shift+Left/Right reach zsh for shift-select word selection
# instead of switching tabs (ghostty's default binding).
keybind = ctrl+shift+arrow_left=unbind
keybind = ctrl+shift+arrow_right=unbind
# Ctrl+Shift+C: forward to zsh (as CSI-u ctrl+shift+c) to copy the keyboard
# selection, instead of ghostty's default mouse-selection copy — unused here,
# and plain Ctrl-C can't do this (see dot_zshrc.tmpl for why).
keybind = ctrl+shift+c=text:\x1b[99;6u
{{ end -}}
