#!/usr/bin/env bash
set -euo pipefail

action="${1:-}"
case "$action" in
  enable | restore) ;;
  *)
    echo "usage: ${0##*/} <enable|restore>" >&2
    exit 2
    ;;
esac

# Adaptive Sync is per-output and Wayland-only. Gate on WAYLAND_DISPLAY rather
# than XDG_SESSION_TYPE: gamemode hooks inherit the former but not the latter.
[[ -n ${WAYLAND_DISPLAY:-} ]] || exit 0
command -v kscreen-doctor >/dev/null 2>&1 || exit 0
command -v jq >/dev/null 2>&1 || exit 0

state_file="${XDG_RUNTIME_DIR:-/tmp}/gamemode-vrr.state"

# vrrPolicy is only present on VRR-capable outputs and holds the libkscreen
# enum: 0 = never, 1 = always, 2 = automatic.
list_outputs() {
  kscreen-doctor --json 2>/dev/null |
    jq -r '.outputs[]
      | select(.enabled and has("vrrPolicy"))
      | "\(.name)\t\(["never", "always", "automatic"][.vrrPolicy] // empty)"'
}

case "$action" in
  enable)
    mapfile -t outputs < <(list_outputs)
    ((${#outputs[@]})) || exit 0

    # Snapshot once: a state file left behind by a crashed session still holds
    # the pre-game policies, and re-snapshotting would capture the forced ones.
    [[ -s $state_file ]] || printf '%s\n' "${outputs[@]}" >"$state_file"

    for entry in "${outputs[@]}"; do
      kscreen-doctor "output.${entry%%$'\t'*}.vrrpolicy.always" >/dev/null
    done
    ;;

  restore)
    [[ -f $state_file ]] || exit 0
    # An output may have gone away mid-session; skip failures.
    while IFS=$'\t' read -r output policy; do
      kscreen-doctor "output.${output}.vrrpolicy.${policy}" >/dev/null || true
    done <"$state_file"
    rm -f "$state_file"
    ;;
esac
